# Parent-owned Atlas configuration for rag-showcase.
# Atlas merges this file into infra/.env on every start through
# ATLAS_ENV_USER_FILE. Use a different external overlay to customize these
# values without editing the vendored Atlas checkout.

PROJECT_NAME=rag-showcase
BRAND_NAME=RAG-SHOWCASE
BRAND_TAGLINE=Six RAG approaches, side by side
BRAND_REPO_URL=https://github.com/thekaveh/rag-showcase
# Atlas's uv dispatcher runs from infra/bootstrapper, so this reaches the
# parent-owned brand asset without embedding a checkout-specific absolute path.
BRAND_LOGO_FILE=../../brand/rag-showcase.logo

# Reproducible LightRAG defaults. Provider/source selection remains Atlas-owned
# and hardware-neutral; these are model roles, not accelerator assumptions.
LIGHTRAG_EMBEDDING_MODEL=nomic-embed-text
LIGHTRAG_EXTRACT_LLM_MODEL=mistral-small3.2:24b
LIGHTRAG_KEYWORD_LLM_MODEL=mistral-small3.2:24b
LIGHTRAG_QUERY_LLM_MODEL=mistral-small3.2:24b
LIGHTRAG_EXTRACT_MAX_ASYNC_LLM=1
LIGHTRAG_EXTRACT_LLM_TIMEOUT=900
OLLAMA_CUSTOM_MODELS=mistral-small3.2:24b
