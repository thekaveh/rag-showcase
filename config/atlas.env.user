# LightRAG runtime defaults imported by the parent-owned atlas.consumer.yml.
# Copy the manifest and this file together when creating a local variant; paths
# in the manifest resolve relative to that manifest.

# Reproducible LightRAG defaults. Provider/source selection remains Atlas-owned
# and hardware-neutral; these are model roles, not accelerator assumptions.
RAG_ROLES_FILE=/app/plugins/rag/roles.yaml
RAG_FLAVORS_FILE=/app/plugins/rag/flavors.yaml
LIGHTRAG_EMBEDDING_MODEL=nomic-embed-text
LIGHTRAG_EXTRACT_LLM_MODEL=mistral-small3.2:24b
LIGHTRAG_KEYWORD_LLM_MODEL=qwen3.6:latest
LIGHTRAG_QUERY_LLM_MODEL=qwen3.6:latest
# Keep roles that depend on Atlas model request defaults behind LiteLLM. A
# native Ollama role call bypasses qwen3.6's catalog-scoped think:false default.
LIGHTRAG_KEYWORD_LLM_BINDING=openai
LIGHTRAG_KEYWORD_LLM_BINDING_HOST=http://litellm:4000/v1
LIGHTRAG_QUERY_LLM_BINDING=openai
LIGHTRAG_QUERY_LLM_BINDING_HOST=http://litellm:4000/v1
LIGHTRAG_EXTRACT_MAX_ASYNC_LLM=1
LIGHTRAG_EXTRACT_LLM_TIMEOUT=900
LIGHTRAG_RERANK_ADAPTER_ENABLED=true
RAGAS_EVALUATOR_MODEL=mistral-small3.2:24b
RAGAS_EMBEDDINGS_MODEL=nomic-embed-text
